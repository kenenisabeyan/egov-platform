POSTGRES_DB=egov
POSTGRES_USER=egov_user
POSTGRES_PASSWORD=egov_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable

REDIS_URL=redis://redis:6379/0
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=egov-bucket

SECRET_KEY=replace-me-with-a-secret-key
DEBUG=0
ALLOWED_HOSTS=localhost,civicflow.et
CSRF_TRUSTED_ORIGINS=https://localhost,https://civicflow.et
SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3
